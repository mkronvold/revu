API_PORT=4000
WEB_PORT=3000
POSTGRES_PORT=5432
POSTGRES_DB=revu
POSTGRES_USER=revu
POSTGRES_PASSWORD=revu
DATABASE_URL=postgresql://revu:revu@db:5432/revu
VITE_API_BASE_URL=/api/v1
VITE_COMPANY_NAME=Your Company
VITE_PROXY_TARGET=http://api:4000
REVU_API_IMAGE=ghcr.io/mkronvold/revu-api
REVU_WEB_IMAGE=ghcr.io/mkronvold/revu-web
REVU_IMAGE_TAG=latest
PROXY_NET_EXTERNAL=true
PROXY_NET_NAME=nginxproxy_proxy-net
BACKUP_ARCHIVE_DIR=/var/lib/revu/backups/archive
BACKUP_HANDOFF_DIR=/var/lib/revu/backups/handoff
BACKUP_CONFIG_DIR=/var/lib/revu/backups/config
BACKUP_STATUS_PATH=/var/lib/revu/backups/config/status.json
BACKUP_AUTOMATIC_ENABLED=false
BACKUP_SCHEDULE=daily
BACKUP_RETENTION_COUNT=14
