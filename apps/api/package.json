{
  "name": "@revu/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build --workspace @revu/contracts && tsx watch --clear-screen=false src/index.ts",
    "build": "npm run build --workspace @revu/contracts && tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "npm run build --workspace @revu/contracts && tsc --project tsconfig.json --noEmit",
    "test": "npm run build --workspace @revu/contracts && vitest run --config vitest.config.ts",
    "seed:example": "npm run build --workspace @revu/contracts && tsx src/seed-example.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@revu/contracts": "file:../../packages/contracts",
    "@types/pg": "^8.20.0",
    "fastify": "^5.2.1",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
