{
  "name": "@revu/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run build --workspace @revu/contracts",
    "dev": "vite --host 0.0.0.0 --port 3000",
    "prebuild": "npm run build --workspace @revu/contracts",
    "build": "tsc --project tsconfig.json && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "pretypecheck": "npm run build --workspace @revu/contracts",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "pretest": "npm run build --workspace @revu/contracts",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@revu/contracts": "file:../../packages/contracts",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.3",
    "vite": "^6.1.0",
    "vitest": "^3.0.6"
  }
}
