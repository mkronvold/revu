{
  "name": "revu",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker compose up web api db",
    "dev:api": "npm run dev --workspace @revu/api",
    "dev:web": "npm run dev --workspace @revu/web",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "validate": "npm test && npm run typecheck && npm run build",
    "compose:config": "docker compose config -q",
    "db:up": "docker compose up -d db",
    "db:migrate": "bash ./scripts/db-migrate.sh",
    "db:down": "docker compose down"
  }
}
